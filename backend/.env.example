# Copy to .env for local dev (python-dotenv loads it automatically).

# Required: your Anthropic API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Required: passcode that unlocks the admin dashboard.
ADMIN_PASSCODE=change-me

# Optional: database. Defaults to a local SQLite file if unset.
# On Render, set this to the managed Postgres connection string.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Optional: model overrides.
# INTERVIEW_MODEL=claude-sonnet-4-6
# SYNTHESIS_MODEL=claude-opus-4-8
